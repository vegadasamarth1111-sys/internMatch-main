# InternMatch backend environment variables

# Database
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/InternMatch

# CORS - comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173

# JWT
JWT_ALGORITHM=EdDSA # keep thsi as EdDSA or one that uses 2 keys 
JWT_PRIVATE_KEY=generated jwt private key
JWT_PUBLIC_KEY=generated jwt public key

## in seconds
JWT_EXPIRE_SECONDS=3600 # 1 hour
JWT_REFRESH_EXPIRE_SECONDS=604800 # 1 week

# OTP (In seconds)
MAX_OTP_ATTEMPTS=5
OTP_EXPIRY_SECONDS=600 # 10 min

GMAIL_USER=your gamil to send otp from
GMAIL_APP_PASS=your 16 digit app password

# File uploads
MAX_UPLOAD_BYTES=5242880 # 5 MB 5 * 1024 * 1024
SUPABASE_URL=your supabase data api url
SUPABASE_KEY=your supabase api key
SUPABASE_BUCKET=your supabase bucket name
