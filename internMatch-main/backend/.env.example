# InternMatch backend environment variables

# Database
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/InternMatch

# CORS - comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173

# JWT
JWT_ALGORITHM=EdDSA  # keep as EdDSA (uses a key-pair)
JWT_PRIVATE_KEY=generated_jwt_private_key
JWT_PUBLIC_KEY=generated_jwt_public_key

## in seconds
JWT_EXPIRE_SECONDS=3600       # 1 hour
JWT_REFRESH_EXPIRE_SECONDS=604800  # 1 week

# OTP (in seconds)
MAX_OTP_ATTEMPTS=5
OTP_EXPIRY_SECONDS=600  # 10 min

# Email (Gmail SMTP)
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASS=your_16_digit_app_password

# Supabase storage
SUPABASE_URL=your_supabase_data_api_url
SUPABASE_KEY=your_supabase_api_key

# The single bucket that holds ALL uploads (resumes, avatars, logos).
# Create this bucket in your Supabase dashboard and make it public.
SUPABASE_BUCKET=internmatch

# Folder prefixes inside SUPABASE_BUCKET.
# You can change these if you want a different folder layout.
# Leave them commented out to use the defaults shown below.
STORAGE_RESUMES_PREFIX=resumes
STORAGE_AVATARS_PREFIX=avatars
STORAGE_LOGOS_PREFIX=logos

# File size limits (bytes)
MAX_UPLOAD_BYTES=5242880    # 5 MB  resume uploads
MAX_AVATAR_BYTES=5242880    # 5 MB  profile pictures and logos

# Admin self-registration
# Generate with: openssl rand -hex 32
# Share ONLY with trusted people who need admin access.
# Set to "disabled" after you have created all admin accounts.
ADMIN_INVITE_SECRET=your-secret-here
